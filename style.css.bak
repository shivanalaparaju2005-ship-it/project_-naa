/* 
 * ANVESHANA INTELLIGENCE OS - Premium Stylesheet
 * Brand Theme: Deep Black, Midnight Blue, Electric Cyan, Neon Purple
 */

@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800&display=swap');

/* --- CUSTOM VARIABLES --- */
:root {
  --bg-primary: #04060a;
  --bg-secondary: #0a0f1d;
  --card-bg: rgba(13, 22, 38, 0.45);
  --card-bg-hover: rgba(18, 30, 51, 0.65);
  --card-border: rgba(0, 240, 255, 0.08);
  --card-border-hover: rgba(0, 240, 255, 0.25);
  
  --color-cyan: #00f0ff;
  --color-cyan-glow: rgba(0, 240, 255, 0.35);
  --color-purple: #8e2de2;
  --color-purple-glow: rgba(142, 45, 226, 0.35);
  --color-green: #00e676;
  --color-red: #ff3838;
  
  --text-primary: #ffffff;
  --text-secondary: #94a3b8;
  --text-muted: #475569;
  
  --sidebar-width: 240px; /* Reduced from 280px to maximize screen resolution fit */
  --header-height: 70px;
  
  --font-sans: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  
  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --glass-blur: blur(12px);
}

/* --- BASE STYLES --- */
html {
  font-size: 14.5px; /* Compact base sizing so the interface fits resolution at 100% zoom */
}

@media (max-width: 1600px) {
  html {
    font-size: 13.5px; /* Automatically scale down content on laptops */
  }
}

@media (max-width: 1200px) {
  html {
    font-size: 13px; /* Scale down content on tablets and small screens */
  }
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: var(--font-sans);
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
  scroll-behavior: smooth;
}

/* --- ANIMATED BACKGROUND --- */
.bg-glowing-orbs {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  overflow: hidden;
  pointer-events: none;
}

.bg-glowing-orbs::before,
.bg-glowing-orbs::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  filter: blur(140px);
  opacity: 0.12;
  animation: drift 25s infinite alternate ease-in-out;
}

.bg-glowing-orbs::before {
  top: -10%;
  left: -10%;
  width: 50vw;
  height: 50vw;
  background: radial-gradient(circle, var(--color-cyan) 0%, transparent 70%);
}

.bg-glowing-orbs::after {
  bottom: -15%;
  right: -10%;
  width: 60vw;
  height: 60vw;
  background: radial-gradient(circle, var(--color-purple) 0%, transparent 70%);
  animation-duration: 35s;
}

.grid-background {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  background-image: 
    linear-gradient(rgba(0, 240, 255, 0.015) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 240, 255, 0.015) 1px, transparent 1px);
  background-size: 50px 50px;
  pointer-events: none;
  opacity: 0.7;
}

/* --- LAYOUT STRUCTURE --- */
#app-container {
  display: flex;
  min-height: 100vh;
  width: 100%;
}

/* --- SIDEBAR --- */
aside.sidebar {
  width: var(--sidebar-width);
  background: rgba(6, 9, 17, 0.85);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-right: 1px solid rgba(255, 255, 255, 0.03);
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  transition: transform var(--transition-normal);
}

.logo-area {
  height: var(--header-height);
  display: flex;
  align-items: center;
  padding: 0 1.5rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}

.logo-text {
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  background: linear-gradient(135deg, #ffffff 30%, var(--color-cyan) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.logo-text i {
  color: var(--color-cyan);
  text-shadow: 0 0 10px var(--color-cyan-glow);
}

.nav-links {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.05) transparent;
}

.nav-links::-webkit-scrollbar {
  width: 4px;
}
.nav-links::-webkit-scrollbar-thumb {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 2px;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  padding: 0.75rem 1rem;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 500;
  border-radius: 8px;
  transition: all var(--transition-fast);
  border: 1px solid transparent;
}

.nav-link:hover {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.02);
  border-color: rgba(0, 240, 255, 0.05);
}

.nav-link.active {
  color: var(--color-cyan);
  background: rgba(0, 240, 255, 0.06);
  border-color: rgba(0, 240, 255, 0.15);
  box-shadow: inset 0 0 10px rgba(0, 240, 255, 0.05);
}

.nav-link i {
  width: 18px;
  font-size: 0.95rem;
  text-align: center;
  transition: transform var(--transition-fast);
}

.nav-link:hover i {
  transform: scale(1.1);
}

.nav-link.active i {
  text-shadow: 0 0 8px var(--color-cyan-glow);
}

.sidebar-footer {
  padding: 1rem 1.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.03);
  font-size: 0.75rem;
  color: var(--text-muted);
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

/* --- MAIN CONTENT CONTAINER --- */
main.main-viewport {
  margin-left: var(--sidebar-width);
  flex: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: margin-left var(--transition-normal);
}

/* --- HEADER BAR --- */
header.header-bar {
  height: var(--header-height);
  background: rgba(6, 9, 17, 0.6);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  position: sticky;
  top: 0;
  z-index: 90;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.mobile-toggle {
  display: none;
  background: transparent;
  border: none;
  color: var(--text-primary);
  font-size: 1.3rem;
  cursor: pointer;
}

.search-container {
  position: relative;
  width: 300px;
}

.search-container i {
  position: absolute;
  left: 0.9rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-secondary);
  font-size: 0.9rem;
}

.global-search-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 30px;
  padding: 0.5rem 1rem 0.5rem 2.2rem;
  color: var(--text-primary);
  font-family: var(--font-sans);
  font-size: 0.85rem;
  transition: all var(--transition-fast);
}

.global-search-input:focus {
  outline: none;
  background: rgba(255, 255, 255, 0.06);
  border-color: var(--color-cyan);
  box-shadow: 0 0 12px var(--color-cyan-glow);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.badge-tag {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.3rem 0.65rem;
  border-radius: 4px;
  border: 1px solid transparent;
}

.badge-verified {
  background: rgba(0, 230, 118, 0.08);
  color: var(--color-green);
  border-color: rgba(0, 230, 118, 0.2);
}

.badge-benchmark {
  background: rgba(0, 240, 255, 0.05);
  color: var(--color-cyan);
  border-color: rgba(0, 240, 255, 0.18);
}

.badge-estimated {
  background: rgba(255, 87, 34, 0.08);
  color: #ff5722;
  border-color: rgba(255, 87, 34, 0.2);
}

.badge-forecast {
  background: rgba(142, 45, 226, 0.08);
  color: #ba68c8;
  border-color: rgba(142, 45, 226, 0.2);
}

.header-btn {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  color: var(--text-primary);
  padding: 0.5rem 0.9rem;
  font-family: var(--font-sans);
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  transition: all var(--transition-fast);
}

.header-btn:hover {
  background: rgba(0, 240, 255, 0.08);
  border-color: var(--color-cyan);
  box-shadow: 0 0 10px var(--color-cyan-glow);
}

.header-btn.accent {
  background: linear-gradient(135deg, var(--color-cyan) 0%, #0082c8 100%);
  border: none;
  color: #04060a;
}

.header-btn.accent:hover {
  filter: brightness(1.15);
  box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
}

/* --- DASHBOARD SECTIONS --- */
.content-wrapper {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.section-container {
  scroll-margin-top: calc(var(--header-height) + 1.5rem);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.25rem;
}

.section-title {
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  display: flex;
  align-items: center;
  gap: 0.65rem;
}

.section-title::after {
  content: '';
  height: 6px;
  width: 6px;
  background-color: var(--color-cyan);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--color-cyan);
}

.section-desc {
  font-size: 0.85rem;
  color: var(--text-secondary);
}

/* --- PREMIUM CARD CLASS --- */
.card-glass {
  background: var(--card-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--card-border);
  border-radius: 12px;
  padding: 1.5rem;
  transition: border-color var(--transition-normal), box-shadow var(--transition-normal), background var(--transition-normal);
  position: relative;
  overflow: hidden;
}

.card-glass:hover {
  background: var(--card-bg-hover);
  border-color: var(--card-border-hover);
  box-shadow: 0 8px 30px rgba(0, 240, 255, 0.03);
}

/* --- SECTION 1: HERO KPI CARDS --- */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.25rem;
}

.kpi-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 140px;
}

.kpi-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--text-secondary);
  font-size: 0.85rem;
  font-weight: 600;
}

.kpi-icon-wrapper {
  height: 32px;
  width: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.kpi-card:hover .kpi-icon-wrapper {
  background: rgba(0, 240, 255, 0.1);
  border-color: var(--color-cyan);
  color: var(--color-cyan);
  box-shadow: 0 0 10px var(--color-cyan-glow);
}

.kpi-value-container {
  margin-top: 0.75rem;
}

.kpi-value {
  font-size: 1.8rem;
  font-weight: 700;
  font-family: var(--font-mono);
  letter-spacing: -0.03em;
  background: linear-gradient(135deg, #ffffff 50%, #d1d5db 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.kpi-footer {
  margin-top: 0.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 0.75rem;
}

.kpi-trend {
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.kpi-trend.up {
  color: var(--color-green);
}

.kpi-trend.down {
  color: var(--color-red);
}

.kpi-trend-period {
  color: var(--text-muted);
}

/* --- SECTION 2: EXECUTIVE COMMAND CENTER --- */
.command-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.chart-container {
  height: 300px;
  position: relative;
  width: 100%;
}

.chart-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 1rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* --- SECTION 3: HEALTH SCORE GAUGES --- */
.health-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
}

.gauge-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 2rem 1.5rem;
}

.gauge-svg-container {
  position: relative;
  width: 140px;
  height: 140px;
  margin-bottom: 1rem;
}

.gauge-svg {
  transform: rotate(-90deg);
  width: 100%;
  height: 100%;
}

.gauge-track {
  fill: none;
  stroke: rgba(255, 255, 255, 0.03);
  stroke-width: 10;
}

.gauge-fill {
  fill: none;
  stroke: var(--color-cyan);
  stroke-width: 10;
  stroke-linecap: round;
  stroke-dasharray: 377;
  stroke-dashoffset: 377;
  transition: stroke-dashoffset 1.5s cubic-bezier(0.4, 0, 0.2, 1);
  filter: drop-shadow(0 0 6px var(--color-cyan-glow));
}

.gauge-score-value {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 1.6rem;
  color: var(--text-primary);
}

.gauge-score-pct {
  font-size: 0.9rem;
  color: var(--text-secondary);
}

.gauge-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.gauge-desc {
  font-size: 0.75rem;
  color: var(--text-secondary);
}

/* Color updates for individual gauges */
.gauge-engagement .gauge-fill {
  stroke: var(--color-purple);
  filter: drop-shadow(0 0 6px var(--color-purple-glow));
}

.gauge-growth .gauge-fill {
  stroke: var(--color-green);
  filter: drop-shadow(0 0 6px rgba(0, 230, 118, 0.35));
}

.gauge-consistency .gauge-fill {
  stroke: #ff9100;
  filter: drop-shadow(0 0 6px rgba(255, 145, 0, 0.35));
}

/* --- SECTION 4: CONTENT PERFORMANCE TABLE --- */
.table-filters {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.25rem;
  flex-wrap: wrap;
}

.filter-group {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.filter-select, .filter-input {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  color: var(--text-primary);
  padding: 0.45rem 0.85rem;
  font-family: var(--font-sans);
  font-size: 0.85rem;
  outline: none;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.filter-select:focus, .filter-input:focus {
  border-color: var(--color-cyan);
  box-shadow: 0 0 8px var(--color-cyan-glow);
}

.filter-select option {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
}

.table-container {
  overflow-x: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.05) transparent;
}

.table-container::-webkit-scrollbar {
  height: 6px;
}
.table-container::-webkit-scrollbar-thumb {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 3px;
}

.performance-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
  font-size: 0.88rem;
}

.performance-table th {
  background: rgba(255, 255, 255, 0.02);
  color: var(--text-secondary);
  font-weight: 600;
  padding: 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  cursor: pointer;
  user-select: none;
  transition: background var(--transition-fast);
}

.performance-table th:hover {
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-primary);
}

.performance-table th i {
  margin-left: 0.35rem;
  font-size: 0.75rem;
}

.performance-table td {
  padding: 0.95rem 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  color: var(--text-secondary);
  white-space: nowrap;
}

.performance-table tr:hover td {
  background: rgba(255, 255, 255, 0.01);
  color: var(--text-primary);
}

.video-name-cell {
  max-width: 280px;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 500;
  color: var(--text-primary);
}

.category-badge {
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-primary);
  font-size: 0.7rem;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  text-transform: uppercase;
  font-weight: 600;
}

.category-badge.budget { color: #81c784; background: rgba(129, 199, 132, 0.08); }
.category-badge.luxury { color: #ffd54f; background: rgba(255, 213, 79, 0.08); }
.category-badge.food { color: #ff8a65; background: rgba(255, 138, 101, 0.08); }
.category-badge.adventure { color: #64b5f6; background: rgba(100, 181, 246, 0.08); }
.category-badge.culture { color: #ba68c8; background: rgba(186, 104, 200, 0.08); }
.category-badge.transport { color: #4db6ac; background: rgba(77, 182, 172, 0.08); }

/* --- SECTION 5: TRAVEL GEOGRAPHY INTELLIGENCE --- */
.map-layout {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1.5rem;
}

.map-wrapper {
  height: 420px;
  width: 100%;
  position: relative;
  border-radius: 8px;
  overflow: hidden;
}

#world-map {
  width: 100%;
  height: 100%;
}

.map-sidebar-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  height: 420px;
  overflow-y: auto;
  padding-right: 0.5rem;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.05) transparent;
}

.map-sidebar-list::-webkit-scrollbar {
  width: 4px;
}
.map-sidebar-list::-webkit-scrollbar-thumb {
  background-color: rgba(255, 255, 255, 0.05);
}

.map-country-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem;
  background: rgba(255, 255, 255, 0.01);
  border: 1px solid rgba(255, 255, 255, 0.02);
  border-radius: 8px;
  transition: all var(--transition-fast);
}

.map-country-item:hover {
  background: rgba(0, 240, 255, 0.03);
  border-color: rgba(0, 240, 255, 0.1);
}

.country-meta {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
}

.country-name {
  font-weight: 600;
  font-size: 0.88rem;
  color: var(--text-primary);
}

.country-views {
  font-size: 0.75rem;
  color: var(--text-secondary);
  font-family: var(--font-mono);
}

.country-rank {
  font-family: var(--font-mono);
  font-weight: 700;
  color: var(--color-cyan);
  font-size: 0.85rem;
}

/* Customizing JSVectorMap styles for dark theme */
.jvm-tooltip {
  background: rgba(10, 15, 28, 0.95) !important;
  backdrop-filter: var(--glass-blur) !important;
  border: 1px solid rgba(0, 240, 255, 0.2) !important;
  border-radius: 8px !important;
  color: var(--text-primary) !important;
  font-family: var(--font-sans) !important;
  padding: 0.75rem 1rem !important;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5) !important;
}

/* --- SECTION 6: CONTENT CATEGORY ANALYSIS --- */
.category-layout {
  display: grid;
  grid-template-columns: 1.2fr 1.8fr;
  gap: 1.5rem;
}

.category-heatmap-wrapper {
  margin-top: 1rem;
  overflow-x: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.05) transparent;
  padding-bottom: 0.5rem;
}

.category-heatmap-wrapper::-webkit-scrollbar {
  height: 4px;
}

.category-heatmap-wrapper::-webkit-scrollbar-thumb {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 2px;
}

.category-matrix {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0.35rem;
  min-width: 500px;
}

.matrix-label-col {
  font-size: 0.75rem;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 0.5rem;
}

.matrix-cell {
  aspect-ratio: 1;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--bg-primary);
  transition: transform var(--transition-fast);
  cursor: pointer;
}

.matrix-cell:hover {
  transform: scale(1.08);
}

/* --- SECTION 7: TITLE INTELLIGENCE LAB --- */
.title-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.25rem;
}

.title-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 220px;
}

.title-type {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-cyan);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
}

.title-desc {
  font-size: 0.8rem;
  color: var(--text-secondary);
  margin-bottom: 1rem;
  line-height: 1.4;
}

.title-metrics {
  border-top: 1px solid rgba(255, 255, 255, 0.03);
  padding-top: 0.75rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.metric-label {
  font-size: 0.7rem;
  color: var(--text-muted);
}

.metric-value {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 1rem;
  color: var(--text-primary);
}

.conversion-pill {
  background: rgba(0, 240, 255, 0.05);
  border: 1px solid rgba(0, 240, 255, 0.15);
  padding: 0.25rem 0.5rem;
  border-radius: 20px;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--color-cyan);
  font-weight: 700;
}

/* --- SECTION 8: THUMBNAIL LAB --- */
.thumbnail-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.25rem;
}

.thumbnail-card {
  padding: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.thumbnail-img-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  background: #0e1626;
  overflow: hidden;
}

.thumbnail-placeholder-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-normal);
}

.thumbnail-card:hover .thumbnail-placeholder-img {
  transform: scale(1.05);
}

.thumbnail-features-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0.5rem;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, transparent 100%);
  display: flex;
  gap: 0.35rem;
  flex-wrap: wrap;
}

.thumb-tag {
  font-size: 0.65rem;
  font-weight: 600;
  background: rgba(0, 240, 255, 0.2);
  border: 1px solid rgba(0, 240, 255, 0.3);
  color: #ffffff;
  padding: 0.1rem 0.35rem;
  border-radius: 2px;
}

.thumbnail-info {
  padding: 1rem;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 0.75rem;
}

.thumbnail-title {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.thumbnail-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid rgba(255, 255, 255, 0.03);
  padding-top: 0.75rem;
}

/* --- SECTION 9: UPLOAD TIMING INTELLIGENCE --- */
.timing-layout {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1.5rem;
}

.calendar-heatmap-container {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  overflow-x: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.05) transparent;
  padding-bottom: 0.5rem;
}

.calendar-heatmap-container::-webkit-scrollbar {
  height: 4px;
}

.calendar-heatmap-container::-webkit-scrollbar-thumb {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 2px;
}

.heatmap-row {
  display: grid;
  grid-template-columns: 50px repeat(24, 1fr);
  gap: 0.25rem;
  min-width: 580px;
}

.heatmap-header-row {
  display: grid;
  grid-template-columns: 50px repeat(24, 1fr);
  gap: 0.25rem;
  font-size: 0.65rem;
  color: var(--text-muted);
  text-align: center;
  min-width: 580px;
}

.day-label {
  font-size: 0.7rem;
  color: var(--text-secondary);
  font-weight: 600;
  display: flex;
  align-items: center;
}

.time-cell {
  aspect-ratio: 1;
  border-radius: 2px;
  background: rgba(255, 255, 255, 0.01);
  transition: transform var(--transition-fast);
  position: relative;
  cursor: pointer;
}

.time-cell:hover {
  transform: scale(1.2);
  z-index: 10;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.time-cell-tooltip {
  visibility: hidden;
  position: absolute;
  bottom: 125%;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(10, 15, 28, 0.95);
  border: 1px solid var(--color-cyan);
  color: var(--text-primary);
  font-size: 0.65rem;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  white-space: nowrap;
  pointer-events: none;
  z-index: 20;
}

.time-cell:hover .time-cell-tooltip {
  visibility: visible;
}

.timing-meta-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 1.25rem;
}

.timing-stat-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 6px;
}

/* --- SECTION 10: COMPETITOR WAR ROOM --- */
.competitor-layout {
  display: grid;
  grid-template-columns: 1.2fr 1.8fr;
  gap: 1.5rem;
}

.radar-chart-wrapper {
  height: 320px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.benchmark-table-wrapper {
  overflow-x: auto;
}

.benchmark-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
  font-size: 0.85rem;
}

.benchmark-table th {
  color: var(--text-secondary);
  font-weight: 600;
  padding: 0.75rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.benchmark-table td {
  padding: 0.85rem 0.75rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  color: var(--text-secondary);
}

.benchmark-table tr.highlight td {
  color: var(--color-cyan);
  font-weight: 600;
  background: rgba(0, 240, 255, 0.02);
}

/* --- SECTION 11: REVENUE OPPORTUNITY CENTER --- */
.revenue-grid {
  display: grid;
  grid-template-columns: 2fr 1.5fr;
  gap: 1.5rem;
}

.calculator-controls {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.slider-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.slider-header {
  display: flex;
  justify-content: space-between;
  font-size: 0.85rem;
}

.slider-label {
  color: var(--text-secondary);
  font-weight: 500;
}

.slider-value {
  color: var(--color-cyan);
  font-weight: 700;
  font-family: var(--font-mono);
}

.revenue-slider {
  -webkit-appearance: none;
  width: 100%;
  height: 5px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 5px;
  outline: none;
  transition: background var(--transition-fast);
}

.revenue-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--color-cyan);
  cursor: pointer;
  box-shadow: 0 0 8px var(--color-cyan);
  transition: transform 0.1s;
}

.revenue-slider::-webkit-slider-thumb:hover {
  transform: scale(1.25);
}

.revenue-output-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(13, 22, 38, 0.8) 0%, rgba(142, 45, 226, 0.05) 100%);
  border-color: rgba(142, 45, 226, 0.2);
}

.rev-output-box {
  text-align: center;
  padding: 1.5rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}

.rev-output-label {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 0.35rem;
}

.rev-output-value {
  font-size: 2.2rem;
  font-weight: 800;
  font-family: var(--font-mono);
  color: var(--color-cyan);
  text-shadow: 0 0 15px var(--color-cyan-glow);
}

.rev-output-breakdown {
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  padding-top: 1rem;
}

.breakdown-row {
  display: flex;
  justify-content: space-between;
  font-size: 0.8rem;
  color: var(--text-secondary);
}

.breakdown-val {
  font-family: var(--font-mono);
  font-weight: 600;
  color: var(--text-primary);
}

/* --- SECTION 12: PREDICTIVE ANALYTICS --- */
.predictive-layout {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1.5rem;
}

.scenario-selector {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.scenario-btn {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 6px;
  color: var(--text-secondary);
  padding: 0.4rem 0.8rem;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.scenario-btn:hover {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.06);
}

.scenario-btn.active {
  background: rgba(0, 240, 255, 0.08);
  border-color: var(--color-cyan);
  color: var(--color-cyan);
}

.forecast-cards {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}

.forecast-item {
  padding: 0.85rem;
  background: rgba(255, 255, 255, 0.01);
  border: 1px solid rgba(255, 255, 255, 0.02);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* --- SECTION 13: STRATEGIC OPPORTUNITY MATRIX --- */
.matrix-layout {
  display: grid;
  grid-template-columns: 1.8fr 1.2fr;
  gap: 1.5rem;
}

.quadrant-container {
  aspect-ratio: 1.6;
  position: relative;
  background: rgba(255, 255, 255, 0.01);
  border: 1px solid rgba(255, 255, 255, 0.03);
  border-radius: 8px;
  overflow: hidden;
}

.matrix-axis-y {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 1px;
  background: rgba(255, 255, 255, 0.08);
}

.matrix-axis-x {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(255, 255, 255, 0.08);
}

.axis-label {
  position: absolute;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--text-muted);
  letter-spacing: 0.05em;
}

.label-high-impact { top: 0.5rem; left: 51%; }
.label-low-impact { bottom: 0.5rem; left: 51%; }
.label-high-effort { right: 0.5rem; top: 51%; }
.label-low-effort { left: 0.5rem; top: 51%; }

.quadrant-label {
  position: absolute;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-muted);
  opacity: 0.3;
}

.ql-1 { top: 1rem; right: 1rem; }
.ql-2 { top: 1rem; left: 1rem; }
.ql-3 { bottom: 1rem; left: 1rem; }
.ql-4 { bottom: 1rem; right: 1rem; }

.matrix-node {
  position: absolute;
  transform: translate(-50%, -50%);
  background: var(--bg-secondary);
  border: 1px solid var(--color-cyan);
  color: var(--text-primary);
  font-size: 0.72rem;
  font-weight: 600;
  padding: 0.35rem 0.65rem;
  border-radius: 20px;
  cursor: pointer;
  white-space: nowrap;
  box-shadow: 0 0 10px rgba(0, 240, 255, 0.15);
  transition: all var(--transition-fast);
}

.matrix-node:hover {
  transform: translate(-50%, -50%) scale(1.08);
  box-shadow: 0 0 15px var(--color-cyan);
  z-index: 10;
}

.matrix-node.purple {
  border-color: var(--color-purple);
  box-shadow: 0 0 10px rgba(142, 45, 226, 0.15);
}

.matrix-node.purple:hover {
  box-shadow: 0 0 15px var(--color-purple);
}

.untapped-listings {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.untapped-box {
  background: rgba(255, 255, 255, 0.01);
  border: 1px solid rgba(255, 255, 255, 0.02);
  border-radius: 8px;
  padding: 0.95rem;
}

.untapped-title {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.untapped-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.untapped-tag {
  font-size: 0.72rem;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  color: var(--text-secondary);
}

/* --- SECTION 14: EXECUTIVE SUMMARY --- */
.boardroom-report {
  background: #ffffff;
  color: #1e293b;
  border-radius: 12px;
  padding: 3rem;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  font-family: 'Outfit', sans-serif;
  border: 1px solid #e2e8f0;
}

.report-header {
  border-bottom: 2px solid #0f172a;
  padding-bottom: 1.5rem;
  margin-bottom: 2rem;
}

.report-title-line {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.report-org {
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  font-weight: 800;
  color: #0f172a;
}

.report-title {
  font-size: 2.2rem;
  font-weight: 800;
  color: #0f172a;
  margin-top: 0.25rem;
}

.report-date {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: #64748b;
  font-weight: 600;
}

.report-body {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 2.5rem;
}

.report-left {
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
}

.report-section-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 0.75rem;
  border-bottom: 1px solid #e2e8f0;
  padding-bottom: 0.35rem;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.report-p {
  font-size: 0.92rem;
  line-height: 1.6;
  color: #334155;
  margin-bottom: 0.75rem;
}

.recommendations-list {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
  padding-left: 1rem;
}

.recommendation-item {
  font-size: 0.9rem;
  line-height: 1.5;
  color: #334155;
}

.recommendation-item strong {
  color: #0f172a;
}

.report-right {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.swot-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.85rem;
}

.swot-box {
  padding: 0.85rem;
  border-radius: 6px;
  border: 1px solid #e2e8f0;
}

.swot-box.s { background: #f0fdf4; border-color: #bbf7d0; }
.swot-box.w { background: #fef2f2; border-color: #fecaca; }
.swot-box.o { background: #eff6ff; border-color: #bfdbfe; }
.swot-box.t { background: #fffbeb; border-color: #fef3c7; }

.swot-title {
  font-size: 0.8rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.25rem;
}

.swot-box.s .swot-title { color: #166534; }
.swot-box.w .swot-title { color: #991b1b; }
.swot-box.o .swot-title { color: #1e40af; }
.swot-box.t .swot-title { color: #854d0e; }

.swot-text {
  font-size: 0.82rem;
  line-height: 1.4;
  color: #475569;
}

/* --- FULL SCREEN DASHBOARD MODE --- */
body.fullscreen-mode aside.sidebar {
  transform: translateX(-100%);
}

body.fullscreen-mode main.main-viewport {
  margin-left: 0;
}

body.fullscreen-mode header.header-bar {
  padding: 0 1rem;
}

/* --- KEYFRAME ANIMATIONS --- */
@keyframes drift {
  0% {
    transform: translate(0, 0) scale(1);
  }
  100% {
    transform: translate(8%, 8%) scale(1.15);
  }
}

/* --- RESPONSIVE LAYOUT ADJUSTMENTS --- */
@media (max-width: 1400px) {
  :root {
    --sidebar-width: 210px; /* Compress sidebar on laptops to maximize viewport space */
  }
  .kpi-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 1200px) {
  .command-grid,
  .health-grid,
  .map-layout,
  .category-layout,
  .timing-layout,
  .competitor-layout,
  .revenue-grid,
  .predictive-layout,
  .matrix-layout,
  .report-body {
    grid-template-columns: 1fr;
  }
  
  .map-sidebar-list {
    height: 250px;
  }
  
  .title-grid,
  .thumbnail-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 900px) {
  aside.sidebar {
    transform: translateX(-100%);
  }
  
  aside.sidebar.mobile-open {
    transform: translateX(0);
  }
  
  main.main-viewport {
    margin-left: 0;
  }
  
  .mobile-toggle {
    display: block;
  }
}

@media (max-width: 600px) {
  .kpi-grid {
    grid-template-columns: 1fr;
  }
  
  .title-grid,
  .thumbnail-grid {
    grid-template-columns: 1fr;
  }
  
  header.header-bar {
    padding: 0 1rem;
  }
  
  .search-container {
    width: 150px;
  }
  
  .content-wrapper {
    padding: 1rem;
  }
  .map-wrapper {
    height: 300px;
  }
}

/* --- CLIENT-SIDE ROUTER / TABS --- */
.section-container {
  display: block !important;
}
body.presentation-mode .section-container {
  display: none !important;
}
body.presentation-mode .section-container.active {
  display: block !important;
}

/* --- DATA GOVERNANCE LAYER --- */
.gov-info-trigger {
  position: relative;
  cursor: pointer;
  color: var(--text-secondary);
  transition: color var(--transition-fast);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
}
.gov-info-trigger:hover {
  color: var(--color-cyan);
}
/* Premium Tooltip styling */
.gov-info-trigger::before {
  content: attr(data-tooltip);
  position: absolute;
  bottom: 130%;
  right: 0;
  width: 220px;
  padding: 0.65rem 0.85rem;
  background: rgba(8, 14, 28, 0.98);
  border: 1px solid rgba(0, 240, 255, 0.25);
  border-radius: 8px;
  color: var(--text-primary);
  font-size: 0.72rem;
  line-height: 1.45;
  white-space: pre-line;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity var(--transition-fast), transform var(--transition-fast);
  transform: translateY(5px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
  z-index: 1000;
  font-family: var(--font-mono);
  font-weight: normal;
  text-align: left;
}
.gov-info-trigger:hover::before {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.card-governance-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
  margin-top: 1.25rem;
  padding-top: 0.85rem;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
  font-size: 0.7rem;
  color: var(--text-secondary);
}
.card-governance-meta strong {
  color: var(--text-primary);
  font-weight: 600;
}
.gov-meta-badge {
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  padding: 0.15rem 0.45rem;
  border-radius: 4px;
  letter-spacing: 0.05em;
}
.gov-meta-badge.badge-verified {
  background: rgba(0, 230, 118, 0.1);
  color: var(--color-green);
  border: 1px solid rgba(0, 230, 118, 0.2);
}
.gov-meta-badge.badge-estimated {
  background: rgba(255, 193, 7, 0.1);
  color: #ffb300;
  border: 1px solid rgba(255, 193, 7, 0.2);
}
.gov-meta-badge.badge-forecast {
  background: rgba(0, 240, 255, 0.1);
  color: var(--color-cyan);
  border: 1px solid rgba(0, 240, 255, 0.2);
}

/* --- EXECUTIVE SUMMARY PAGE --- */
.boardroom-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.5rem;
  margin-top: 0.5rem;
}
.exec-card {
  padding: 1.75rem;
  border-radius: 12px;
  background: rgba(10, 16, 30, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.03);
}
.exec-card-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  padding-bottom: 0.75rem;
}
.exec-card-title i {
  color: var(--color-cyan);
  text-shadow: 0 0 8px var(--color-cyan-glow);
}
.exec-list {
  padding-left: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}
.exec-list li {
  font-size: 0.84rem;
  line-height: 1.55;
  color: var(--text-secondary);
}
.exec-list li strong {
  color: var(--text-primary);
}

/* --- DATA METHODOLOGY PAGE --- */
.methodology-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.methodology-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 0.85rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.methodology-title i {
  color: var(--color-cyan);
}
.methodology-p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 1rem;
}
.methodology-list {
  padding-left: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}
.methodology-list li {
  font-size: 0.82rem;
  color: var(--text-secondary);
  line-height: 1.45;
}
.methodology-list li strong {
  color: var(--text-primary);
}
.framework-table-wrapper {
  overflow-x: auto;
  margin-top: 0.5rem;
}
.framework-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.8rem;
  text-align: left;
}
.framework-table th {
  color: var(--text-secondary);
  font-weight: 600;
  padding: 0.6rem 0.5rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}
.framework-table td {
  padding: 0.65rem 0.5rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  color: var(--text-secondary);
  vertical-align: middle;
}

.formula-flex-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}
.formula-box {
  background: rgba(255, 255, 255, 0.015);
  border: 1px solid rgba(255, 255, 255, 0.03);
  border-radius: 8px;
  padding: 1.25rem;
}
.formula-name {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 0.65rem;
  font-family: var(--font-sans);
}
.formula-math {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--color-cyan);
  background: rgba(0, 240, 255, 0.03);
  padding: 0.75rem;
  border-radius: 6px;
  border: 1px dashed rgba(0, 240, 255, 0.15);
  margin-bottom: 0.65rem;
  overflow-x: auto;
  white-space: nowrap;
}
.formula-desc {
  font-size: 0.72rem;
  color: var(--text-secondary);
  line-height: 1.45;
}

/* --- CONSULTING INSIGHT PANELS --- */
.insight-panel-container {
  width: 100%;
}
.insight-card {
  border-left: 4px solid var(--color-cyan) !important;
  background: rgba(10, 16, 30, 0.6) !important;
}
.insight-card.underperforming {
  border-left-color: var(--color-red) !important;
}
.insight-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.insight-title i {
  color: var(--color-cyan);
}
.insight-card.underperforming .insight-title i {
  color: var(--color-red);
}
.insight-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}
.insight-col {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.insight-col strong {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-secondary);
  font-weight: 700;
}
.insight-col p {
  font-size: 0.78rem;
  line-height: 1.45;
  color: var(--text-primary);
}

/* --- UPGRADED STRATEGIC MATRIX GRID --- */
.matrix-node.green {
  background: rgba(0, 230, 118, 0.25);
  border-color: var(--color-green);
  box-shadow: 0 0 10px rgba(0, 230, 118, 0.15);
}
.matrix-node.green:hover {
  background: rgba(0, 230, 118, 0.45);
  box-shadow: 0 0 15px rgba(0, 230, 118, 0.35);
}
.matrix-node.yellow {
  background: rgba(255, 193, 7, 0.25);
  border-color: #ffb300;
  box-shadow: 0 0 10px rgba(255, 193, 7, 0.15);
}
.matrix-node.yellow:hover {
  background: rgba(255, 193, 7, 0.45);
  box-shadow: 0 0 15px rgba(255, 193, 7, 0.35);
}
.matrix-node.red {
  background: rgba(255, 56, 56, 0.25);
  border-color: var(--color-red);
  box-shadow: 0 0 10px rgba(255, 56, 56, 0.15);
}
.matrix-node.red:hover {
  background: rgba(255, 56, 56, 0.45);
  box-shadow: 0 0 15px rgba(255, 56, 56, 0.35);
}

/* --- BOARDROOM PRESENTATION MODE --- */
body.presentation-mode {
  overflow-y: auto;
}
body.presentation-mode aside.sidebar {
  transform: translateX(-100%) !important;
}
body.presentation-mode main.main-viewport {
  margin-left: 0 !important;
  padding-bottom: 80px; /* Space for bottom nav */
}
body.presentation-mode header.header-bar {
  display: none !important; /* Hide standard header */
}
body.presentation-mode .table-filters,
body.presentation-mode .scenario-selector,
body.presentation-mode .calculator-controls,
body.presentation-mode .global-search-input,
body.presentation-mode .search-container {
  display: none !important; /* Hide filters and inputs */
}

/* Floating exit button in bottom right as fallback */
.exit-presentation-btn {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 10000;
  background: linear-gradient(135deg, var(--color-red) 0%, #b71c1c 100%);
  color: #fff;
  border: none;
  border-radius: 30px;
  padding: 0.65rem 1.25rem;
  font-family: var(--font-sans);
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  box-shadow: 0 5px 15px rgba(255, 56, 56, 0.3);
  transition: all var(--transition-fast);
}
.exit-presentation-btn:hover {
  filter: brightness(1.15);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(255, 56, 56, 0.4);
}

/* Slideshow Bottom Nav bar */
#presentation-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 60px;
  background: rgba(5, 8, 16, 0.95);
  border-top: 1px solid rgba(0, 240, 255, 0.25);
  backdrop-filter: blur(15px);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
  box-shadow: 0 -5px 25px rgba(0, 0, 0, 0.6);
}
.pres-nav-btn {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: var(--text-primary);
  padding: 0.45rem 1rem;
  font-family: var(--font-sans);
  font-size: 0.8rem;
  font-weight: 600;
  border-radius: 6px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  transition: all var(--transition-fast);
}
.pres-nav-btn:hover {
  background: rgba(0, 240, 255, 0.08);
  border-color: var(--color-cyan);
  box-shadow: 0 0 10px var(--color-cyan-glow);
}
.pres-nav-btn:disabled {
  opacity: 0.35;
  cursor: not-allowed;
  background: transparent;
  border-color: rgba(255, 255, 255, 0.02);
}
.pres-indicator {
  font-family: var(--font-sans);
  font-size: 0.85rem;
  color: var(--text-secondary);
}
.pres-indicator strong {
  color: var(--color-cyan);
}

