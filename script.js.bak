          'AQ': 'visited'
        }
      }]
    },
    // Suppress built-in tooltip — custom tooltip handles all display
    showTooltip: false
  });

  // ── FULL ISO 3166-1 COUNTRY NAME LOOKUP ──────────────────────────────────
  const COUNTRY_NAMES = {
    AF:'Afghanistan',AX:'Åland Islands',AL:'Albania',DZ:'Algeria',AS:'American Samoa',
