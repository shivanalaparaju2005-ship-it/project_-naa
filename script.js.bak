        values: {
          'IN': 'visited', 'CN': 'visited', 'TH': 'visited', 'AE': 'visited',
          'VN': 'visited', 'IR': 'visited', 'AZ': 'visited', 'BH': 'visited',
          'AF': 'visited', 'PK': 'visited', 'HK': 'visited',
